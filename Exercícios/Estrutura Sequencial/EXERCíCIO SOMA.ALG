Algoritmo "Exercício Soma"
// 
//  
// Descriçăo   : Exercício Estrutura Sequencial
// Autor(a)    : Cleiber Dorneles
// Data atual  : 04/06/2026
Var
// Seçăo de Declaraçőes das variáveis 
    x, y, soma: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 

   escreval("Insira o Primeiro valor:")
   leia(x)
   escreval("Insira o Segundo valor:")
   leia(y)
   soma <- x+y
   escreval("A Soma dos valores é:" ,soma)
Fimalgoritmo