Algoritmo "Exercício Retangulo"
// 
//  
// Descriçăo   : Exercício Estrutura Sequencial
// Autor(a)    : Cleiber Dorneles
// Data atual  : 04/06/2026
Var
// Seçăo de Declaraçőes das variáveis 
   base, altura, area, diagonal, perimetro:real
   
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Base:")
   leia(base)
   escreva("Altura:")
   leia(altura)
   area <- base*altura
   perimetro <- base*2 + altura*2
   diagonal <- raizq(base^2 + altura^2)
   escreval("Área:" ,area:0:4)
   escreval("Perimętro:" ,perimetro:0:4)
   escreval("Diagonal:" ,diagonal:0:4)

Fimalgoritmo